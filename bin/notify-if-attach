#!/usr/bin/env bash

set -euo pipefail

script_path="${BASH_SOURCE[0]}"

if [[ "$script_path" != */* ]]; then
  script_path="$(command -v -- "$script_path")"
fi

while [[ -L "$script_path" ]]; do
  script_dir="${script_path%/*}"
  script_dir="$(cd -P "$script_dir" && pwd)"
  script_path="$(readlink "$script_path")"
  if [[ "$script_path" != /* ]]; then
    script_path="$script_dir/$script_path"
  fi
done

script_dir="${script_path%/*}"
script_dir="$(cd -P "$script_dir" && pwd)"
source "$script_dir/../lib/attach-state.sh"

if [[ $# -ne 2 && $# -ne 3 ]]; then
  printf 'usage: %s <event> [title] <message>\n' "${0##*/}" >&2
  exit 64
fi

event="$1"

if [[ $# -eq 2 ]]; then
  title="OpenCode attach: $event"
  message="$2"
else
  title="$2"
  message="$3"
fi

if ! attach_state_has_active; then
  exit 0
fi

if ! command -v notify-send >/dev/null 2>&1; then
  printf 'notify-send is required for attach notifications\n' >&2
  exit 1
fi

notify-send --app-name OpenCode -- "$title" "$message"
